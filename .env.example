# Alibaba Cloud credentials
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret

# CMS workspace and memory store
ALIBABA_CLOUD_WORKSPACE=your_workspace_name
ALIBABA_CLOUD_MEMORY_STORE=your_memory_store_name

# Optional: region (default: cn-hangzhou)
# ALIBABA_CLOUD_REGION_ID=cn-hangzhou

# Optional: server port (default: 8765)
# MCP_PORT=8765
